#!/usr/bin/env python3
"""
GitHub Statistics Context Plugin

Fetches current repository statistics and recent activity.
Outputs formatted Markdown for agent context.

Usage: Place in context.d/ directory of your Boucle agent.
Requires: GITHUB_TOKEN environment variable
"""

import os
import sys
from datetime import datetime, timedelta
from pathlib import Path

def main():
    print("## GitHub Repository Monitoring")
    print()

    # Check for GitHub token
    token = os.getenv('GITHUB_TOKEN')
    if not token:
        print("⚠️  **Configuration Required**")
        print("Set GITHUB_TOKEN environment variable to enable monitoring.")
        print()
        return

    try:
        from github import Github
        from dotenv import load_dotenv
    except ImportError:
        print("⚠️  **Dependencies Missing**")
        print("Install required packages: `pip install PyGithub python-dotenv`")
        print()
        return

    load_dotenv()
    g = Github(token)

    # Get user's repositories (configurable in real implementation)
    try:
        user = g.get_user()
        repos = list(user.get_repos(sort='updated', direction='desc'))[:5]

        print(f"**Monitoring {len(repos)} repositories for @{user.login}**")
        print()

        for repo in repos:
            analyze_repository(repo)

        print("---")
        print(f"*Last updated: {datetime.now().strftime('%Y-%m-%d %H:%M:%S UTC')}*")

    except Exception as e:
        print(f"❌ **Error fetching repositories:** {str(e)}")
        print()

def analyze_repository(repo):
    """Analyze a single repository and output status."""
    print(f"### {repo.full_name}")

    # Basic stats
    print(f"- **Language:** {repo.language or 'Not detected'}")
    print(f"- **Stars:** {repo.stargazers_count}")
    print(f"- **Issues:** {repo.open_issues_count} open")
    print(f"- **Last updated:** {repo.updated_at.strftime('%Y-%m-%d')}")

    # Recent activity analysis
    try:
        # Get recent commits
        commits = list(repo.get_commits(since=datetime.now() - timedelta(days=7)))
        print(f"- **Activity:** {len(commits)} commits in last 7 days")

        # Get recent issues
        issues = list(repo.get_issues(state='open', sort='created', direction='desc'))[:3]
        if issues:
            print("- **Recent issues:**")
            for issue in issues:
                age_days = (datetime.now().replace(tzinfo=None) -
                           issue.created_at.replace(tzinfo=None)).days
                print(f"  - [#{issue.number}] {issue.title[:50]}... ({age_days}d old)")

        # Check for security alerts (if accessible)
        try:
            alerts = list(repo.get_vulnerability_alerts())
            if alerts:
                print(f"- ⚠️  **Security alerts:** {len(alerts)} active")
        except:
            pass  # Not always accessible

    except Exception as e:
        print(f"- ⚠️  Limited data: {str(e)[:50]}")

    print()

if __name__ == '__main__':
    main()