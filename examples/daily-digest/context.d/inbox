#!/bin/bash
# List files in the inbox for the agent to summarize
echo "## Inbox"
echo ""
AGENT_DIR="${1:-.}"
INBOX="$AGENT_DIR/inbox"
if [ ! -d "$INBOX" ] || [ -z "$(ls "$INBOX" 2>/dev/null)" ]; then
    echo "No new files."
else
    for f in "$INBOX"/*; do
        echo "### $(basename "$f")"
        cat "$f"
        echo ""
    done
fi
